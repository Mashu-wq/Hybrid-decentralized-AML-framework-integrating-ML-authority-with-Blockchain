// Package service contains the KYC business logic layer.
// All PII encryption/decryption is delegated to the EncryptionClient.
// PII values MUST NOT appear in any log output.
package service

import (
	"context"
	"fmt"
	"strings"
	"time"

	"github.com/fraud-detection/kyc-service/internal/clients"
	"github.com/fraud-detection/kyc-service/internal/config"
