// ListByStatus
// ---------------------------------------------------------------------------

// ListByStatus returns a paginated list of customers in the given KYC status.
func (s *KYCService) ListByStatus(
	ctx context.Context,
	status domain.KYCStatus,
	countryCode string,
	limit, offset int,
) ([]*domain.Customer, int, error) {
	if limit <= 0 {
		limit = 20
	}
	if limit > 100 {
		limit = 100
	}

	customers, total, err := s.repo.ListByStatus(ctx, status, countryCode, limit, offset)
	if err != nil {
		return nil, 0, fmt.Errorf("list by status: %w", err)
	}
	return customers, total, nil
}

// ---------------------------------------------------------------------------
// GetDecryptedPII
// ---------------------------------------------------------------------------

// GetDecryptedPIIResult carries the decrypted PII values.
// DO NOT LOG any fields in this struct.
type GetDecryptedPIIResult struct {
	CustomerID     string
	FullName       string // DO NOT LOG
	DateOfBirth    string // DO NOT LOG
	AddressLine1   string // DO NOT LOG
	AddressLine2   string // DO NOT LOG
	Email          string // DO NOT LOG
	PhoneNumber    string // DO NOT LOG
	DocumentNumber string // DO NOT LOG
	ExpiryDate     string // DO NOT LOG
}

// GetDecryptedPII decrypts and returns all PII fields for a customer.
// Every call is audit-logged with the actor ID and reason.
// NEVER log the returned struct or any of its fields.
func (s *KYCService) GetDecryptedPII(ctx context.Context, customerID, actorID, reason string) (*GetDecryptedPIIResult, error) {
	// Verify customer exists (returns non-PII record).
	if _, err := s.repo.GetCustomerByID(ctx, customerID); err != nil {
		return nil, fmt.Errorf("verify customer: %w", err)
	}

	// Fetch encrypted PII ciphertexts.
	encPII, err := s.repo.GetEncryptedPII(ctx, customerID)
	if err != nil {
		return nil, fmt.Errorf("get encrypted PII: %w", err)
	}

	// Batch decrypt via Encryption Service.
	ciphertexts := map[string]string{
		"full_name":       encPII.FullNameEnc,
		"date_of_birth":   encPII.DateOfBirthEnc,
		"address_line1":   encPII.AddressLine1Enc,
		"address_line2":   encPII.AddressLine2Enc,
		"email":           encPII.EmailEnc,
		"phone_number":    encPII.PhoneNumberEnc,
		"document_number": encPII.DocumentNumberEnc,
		"expiry_date":     encPII.ExpiryDateEnc,
	}

	decrypted, err := s.enc.BatchDecryptPII(ctx, customerID, ciphertexts)
	if err != nil {
		return nil, fmt.Errorf("decrypt PII: %w", err)
	}

	// Audit log BEFORE returning (do not log PII values).
	s.logAudit(ctx, &domain.AuditEvent{
		CustomerID: customerID,
		EventType:  "PII_ACCESSED",
		ActorID:    actorID,
		Reason:     reason,
		Metadata: map[string]string{
			"fields_accessed": "full_name,date_of_birth,address_line1,address_line2,email,phone_number,document_number,expiry_date",
		},
		CreatedAt: time.Now().UTC(),
	})

	s.log.Info().
		Str("customer_id", customerID).
		Str("actor_id", actorID).
		Msg("PII accessed — audit event logged") // DO NOT LOG decrypted values

	// Map decrypted bytes to strings. DO NOT LOG this struct.
	result := &GetDecryptedPIIResult{
		CustomerID:     customerID,
		FullName:       string(decrypted["full_name"]),
		DateOfBirth:    string(decrypted["date_of_birth"]),
		AddressLine1:   string(decrypted["address_line1"]),
		AddressLine2:   string(decrypted["address_line2"]),
		Email:          string(decrypted["email"]),
		PhoneNumber:    string(decrypted["phone_number"]),
		DocumentNumber: string(decrypted["document_number"]),
		ExpiryDate:     string(decrypted["expiry_date"]),
	}

	return result, nil
}

