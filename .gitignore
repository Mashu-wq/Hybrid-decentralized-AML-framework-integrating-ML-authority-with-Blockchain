# =============================================================================
# FRAUD DETECTION SYSTEM — .gitignore
# =============================================================================


# Keep example env
!.env.example

# Go workspace
go.work.sum

# OS temp
.Trash/
*.tmp
*.temp

# DB files
*.db
*.sqlite
*.sqlite3

# Notebooks
.ipynb_checkpoints/

# Extra binaries
*.bin
*.cover

# Go cache
.gocache/
.gomodcache/

# Tool/editor cache
.claude/

# --- Secrets & Environment ---
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12
*_credentials.json
vault-token

# --- Go ---
/vendor/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.sum.backup
bin/
dist/
tmp/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc
*.pyo
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/

# --- Python Virtual Environments ---
venv/
env/
ENV/
.venv/
.env_ml/

# --- Poetry ---
.venv

# --- ML / Data ---
ml/data/raw/
ml/data/processed/
ml/artifacts/
ml/mlruns/
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx
*.npy
*.npz
wandb/

# --- Node / Frontend ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Docker ---
docker-compose.override.yml

# --- Kubernetes ---
infrastructure/kubernetes/secrets/
*.kubeconfig
kubeconfig

# --- Terraform ---
infrastructure/terraform/.terraform/
infrastructure/terraform/*.tfstate
infrastructure/terraform/*.tfstate.backup
infrastructure/terraform/*.tfvars
infrastructure/terraform/.terraform.lock.hcl
infrastructure/terraform/crash.log

# --- Blockchain / Hyperledger ---
blockchain/network/organizations/
blockchain/network/channel-artifacts/
blockchain/wallet/
blockchain/network/system-genesis-block/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Test Artifacts ---
test-results/
coverage/
*.coverprofile

# --- Generated Protobuf ---
# Keep .proto files, ignore generated stubs (regenerate via make proto)
proto/gen/

# --- Local scripts output ---
scripts/output/
