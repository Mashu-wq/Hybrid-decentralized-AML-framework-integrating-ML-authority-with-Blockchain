# =============================================================================
# FRAUD DETECTION SYSTEM — ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# --- Project ---
PROJECT_NAME=fraud-detection-system
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=info            # debug | info | warn | error

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraud_detection
POSTGRES_USER=fraud_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_SSL_MODE=disable  # require in production

# --- MongoDB ---
MONGO_URI=mongodb://mongo_user:changeme@localhost:27017/fraud_detection
MONGO_DB=fraud_detection
MONGO_USER=mongo_user
MONGO_PASSWORD=changeme_strong_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_DB=0
REDIS_TLS=false  # true in production

# --- Apache Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_KYC_EVENTS=kyc.events
KAFKA_TOPIC_TX_RAW=transactions.raw
KAFKA_TOPIC_ALERTS=alerts.created
KAFKA_TOPIC_AUDIT=audit.events
KAFKA_CONSUMER_GROUP=fraud-detection-cg
KAFKA_SASL_ENABLED=false         # true in production
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=changeme

# --- HashiCorp Vault ---
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=dev-root-token       # NEVER use in production — use AppRole
VAULT_TRANSIT_KEY=fraud-pii-key
VAULT_MOUNT_PATH=transit
VAULT_APPROLE_ROLE_ID=           # production: set via CI/CD
VAULT_APPROLE_SECRET_ID=         # production: set via CI/CD

# --- JWT / IAM ---
JWT_SECRET=changeme_min_32_chars_jwt_secret_key_here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h   # 7 days
JWT_ISSUER=fraud-detection-system
MFA_ISSUER=FraudDetectionSystem
BCRYPT_COST=12

# --- ML Service ---
ML_SERVICE_HOST=localhost
ML_SERVICE_GRPC_PORT=50051
ML_SERVICE_HTTP_PORT=8000
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection
MODEL_FRAUD_THRESHOLD=0.7        # probability above which alert is raised
MODEL_ARTIFACT_PATH=./ml/artifacts

# --- Blockchain / Hyperledger Fabric ---
FABRIC_CONFIG_PATH=./blockchain/network
FABRIC_WALLET_PATH=./blockchain/wallet
FABRIC_MSP_ID=Org1MSP
FABRIC_PEER_ENDPOINT=localhost:7051
FABRIC_ORDERER_ENDPOINT=localhost:7050
FABRIC_CHANNEL_KYC=kyc-channel
FABRIC_CHANNEL_ALERT=alert-channel
FABRIC_CHANNEL_AUDIT=audit-channel
FABRIC_TLS_ENABLED=false         # true in production

# --- AWS (for production features) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=               # set via IAM role in EKS
AWS_SECRET_ACCESS_KEY=           # set via IAM role in EKS
AWS_S3_EVIDENCE_BUCKET=fraud-evidence-bucket
AWS_S3_REPORTS_BUCKET=fraud-reports-bucket
AWS_TEXTRACT_REGION=us-east-1

# --- Notifications ---
SENDGRID_API_KEY=                # optional: email alerts
TWILIO_ACCOUNT_SID=              # optional: SMS alerts
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SLACK_WEBHOOK_URL=               # optional: Slack alerts

# --- API Gateway ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Services Ports ---
API_GATEWAY_PORT=8080
IAM_SERVICE_PORT=9000
IAM_SERVICE_GRPC_PORT=50060
KYC_SERVICE_PORT=9001
KYC_SERVICE_GRPC_PORT=50061
TX_SERVICE_PORT=9002
TX_SERVICE_GRPC_PORT=50062
ALERT_SERVICE_PORT=9003
ALERT_SERVICE_GRPC_PORT=50063
CASE_SERVICE_PORT=9004
BLOCKCHAIN_SERVICE_PORT=9005
BLOCKCHAIN_SERVICE_GRPC_PORT=50065
ANALYTICS_SERVICE_PORT=9006
ENCRYPTION_SERVICE_GRPC_PORT=50066

# --- Observability ---
JAEGER_ENDPOINT=http://localhost:14268/api/traces
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password

# --- Rate Limiting ---
RATE_LIMIT_PUBLIC_RPM=100        # requests per minute per API key
RATE_LIMIT_SERVICE_RPM=1000
RATE_LIMIT_LOCKOUT_ATTEMPTS=5
RATE_LIMIT_LOCKOUT_DURATION=15m
